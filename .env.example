DATABASE_URL=

# Google OAuth (free via Google Cloud Console)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Notion Internal Integration (create at notion.so/my-integrations)
# NOTE: per-user Notion tokens are pasted in Settings; these env vars are only
# used as a fallback for development.
NOTION_API_KEY=
NOTION_JOURNAL_PAGE_ID=

# AI — OpenRouter (unified gateway for all models). Falls back to this when
# a user has not pasted their own key in Settings.
OPENROUTER_API_KEY=

# Vercel Blob — for storing Notion images durably (Notion URLs expire in ~1h).
# Vercel injects this automatically when you add a Blob store in the project
# dashboard. For local dev, copy BLOB_READ_WRITE_TOKEN from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# Email notifications (Resend — free tier: 3,000/month, single sender).
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: used in email links so "Review & approve" opens the right URL.
# Defaults to http://localhost:5176 in dev.
PUBLIC_APP_URL=

# Cron secret. Vercel auto-attaches `Authorization: Bearer ${CRON_SECRET}` to
# every cron-triggered request. The /api/cron/run-automations route refuses
# requests without a matching secret. Generate with: openssl rand -base64 32
CRON_SECRET=
